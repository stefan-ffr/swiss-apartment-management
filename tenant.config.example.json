{
  "$schema": "./packages/core/tenant.schema.json",

  "tenant": {
    "id": "example-stweg",
    "name": "Beispiel STWEG-Kooperation",
    "domain": "example.ch",
    "locale": "de-CH",
    "timezone": "Europe/Zurich"
  },

  "stwegen": [
    {
      "nr": 1,
      "name": "STWEG 1",
      "addresses": ["Musterstrasse 17", "Musterstrasse 18"],
      "groups": {
        "bewohner": "stweg1-bewohner",
        "eigentuemer": "stweg1-eigentuemer",
        "ausschuss": "stweg1-ausschuss"
      },
      "type": "wohnung"
    },
    {
      "nr": 8,
      "name": "Tiefgarage",
      "addresses": [],
      "groups": { "ausschuss": "stweg8-ausschuss" },
      "type": "tiefgarage"
    }
  ],

  "auth": {
    "provider": "authentik",
    "issuerUrl": "https://auth.example.ch/application/o/swiss-apartment-management/",
    "externalUrl": "https://auth.example.ch",
    "internalUrl": "http://authentik_server:9443",
    "clientId": "REPLACE_ME",
    "clientSecret": "REPLACE_ME",
    "adminGroups": ["technik", "praesident"]
  },

  "database": {
    "host": "postgres",
    "port": 5432,
    "name": "sam",
    "user": "sam",
    "passwordEnv": "DB_PASSWORD"
  },

  "smtp": {
    "host": "smtp.example.ch",
    "port": 587,
    "user": "no-reply@example.ch",
    "passwordEnv": "SMTP_PASSWORD",
    "from": "Beispiel STWEG <no-reply@example.ch>"
  },

  "storage": {
    "type": "local",
    "path": "/var/lib/sam/documents"
  },

  "modules": {
    "wohnungen": {
      "enabled": true,
      "options": {
        "permissionKey": "wohnungen",
        "historyPermissionKey": "wohnungen-historie"
      }
    },
    "verwaltung": {
      "enabled": true,
      "options": {
        "permissionKey": "verwaltung",
        "exposePublicEndpoint": true
      }
    },
    "verteiler": {
      "enabled": true,
      "options": {
        "domain": "lists.example.ch",
        "fromAddress": "noreply@example.ch",
        "permissionKey": "verteiler",
        "rateLimitMax": 10,
        "rateLimitWindowMs": 600000,
        "recipientBlocklistPatterns": [
          "^drucker[a-z0-9]*@",
          ".*\\.invalid$"
        ],
        "loopSubjectPrefixes": ["Zustellbericht:", "Auto-Reply:"],
        "loopHeaderNames":     ["x-forwarded-by-sam"],
        "loopHeaderValue":     "sam-verteiler"
      }
    },
    "drucker": {
      "enabled": false,
      "options": {
        "tagPrefix": "drucker",
        "domain": "print.example.ch",
        "publicBaseUrl": "https://stweg.example.ch",
        "permissionKey": "drucker",
        "autoCancelAfterDays": 30
      }
    },
    "waschkueche": {
      "enabled": false,
      "options": {
        "permissionKey": "waschkueche",
        "maxSlotMinutes": 240,
        "maxAdvanceDays": 28,
        "allowRecurring": true,
        "costPerKwh": 0.30
      }
    },
    "energie": {
      "enabled": false,
      "options": {
        "readPermissionKey": "energie",
        "ingestHeaderName": "x-sam-ingest-key",
        "ingestSecretEnv": "SAM_ENERGIE_INGEST_KEY",
        "defaultUnit": "kWh"
      }
    },
    "telefonbuch": {
      "enabled": true,
      "options": {
        "uidPrefix": "example",
        "category": "Example Phonebook",
        "internalEmailPatterns": ["^drucker[a-z0-9]*\\+.*"],
        "syncIntervalMs": 3600000
      }
    },
    "unterschriftenlisten": {
      "enabled": true,
      "options": {
        "permissionKey": "unterschriftenlisten",
        "pdfRoot": "/var/lib/sam/documents/unterschriftenlisten",
        "verificationPageUrl": "https://stweg.example.ch/echtheitspruefung.html"
      }
    },
    "smtp2go": {
      "enabled": false,
      "options": {
        "permissionKey": "smtp2go",
        "smtp": {
          "host": "mail.smtp2go.com",
          "port": 587,
          "secure": false,
          "userEnv": "SMTP2GO_USER",
          "passwordEnv": "SMTP2GO_PASSWORD",
          "from": "noreply@example.ch"
        },
        "webhook": {
          "secretEnv": "SMTP2GO_WEBHOOK_SECRET",
          "signatureHeader": "x-sam-signature",
          "algorithm": "sha256"
        },
        "imap": {
          "host": "imap.gmail.com",
          "port": 993,
          "secure": true,
          "userEnv": "GMAIL_USER",
          "passwordEnv": "GMAIL_APP_PASSWORD",
          "mailbox": "INBOX",
          "tagPrefixFilter": "list",
          "moveProcessedTo": "Processed",
          "pollIntervalMs": 60000
        },
        "activityApi": {
          "baseUrl": "https://api.smtp2go.com/v3",
          "apiKeyEnv": "SMTP2GO_API_KEY",
          "syncIntervalMs": 600000
        }
      }
    },
    "mailcow": {
      "enabled": false,
      "options": {
        "apiUrl": "https://mail.example.ch",
        "apiKeyEnv": "MAILCOW_API_KEY",
        "defaultDomain": "example.ch",
        "permissionKey": "mailcow",
        "defaultQuotaMb": 1024,
        "smtp": {
          "host": "mail.example.ch",
          "port": 587,
          "secure": false,
          "userEnv": "MAILCOW_SMTP_USER",
          "passwordEnv": "MAILCOW_SMTP_PASSWORD",
          "from": "noreply@example.ch"
        },
        "imap": {
          "host": "mail.example.ch",
          "port": 993,
          "secure": true,
          "userEnv": "MAILCOW_IMAP_USER",
          "passwordEnv": "MAILCOW_IMAP_PASSWORD",
          "mailbox": "INBOX",
          "moveProcessedTo": "Processed",
          "pollIntervalMs": 60000
        },
        "bridges": {
          "verteiler": {
            "enabled": true,
            "auditBcc": "verteiler-log@example.ch",
            "maxRecipientsPerAlias": 1000,
            "syncIntervalMs": 900000
          },
          "drucker": {
            "enabled": true,
            "ingestAddress": "printer-ingest@example.ch",
            "syncIntervalMs": 900000
          }
        }
      }
    }
  },

  "branding": {
    "logoPath": "/branding/logo.png",
    "primaryColor": "#2563eb",
    "favicon": "/branding/favicon.ico"
  }
}

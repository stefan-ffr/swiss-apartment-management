# Copy to `.env` and fill in. Used by docker-compose and the host
# in dev. In production, secrets should come from your secret store
# (Docker Swarm secrets, Kubernetes Secrets, Proxmox host env, ...).

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_DB=sam
POSTGRES_USER=sam
POSTGRES_PASSWORD=change-me

# ── Host ─────────────────────────────────────────────────────
SAM_PORT=3000
LOG_LEVEL=info

# ── SMTP submission (mailpit/mailcow) ────────────────────────
MAILCOW_SMTP_USER=noreply@example.test
MAILCOW_SMTP_PASSWORD=anything

# ── Energy ingest (collector → API shared secret) ────────────
SAM_ENERGIE_INGEST_KEY=change-me

# ── Optional: Mailcow API ────────────────────────────────────
# Empty disables the mailcow integration
MAILCOW_API_KEY=

# ── Optional: Nextcloud / CardDAV app password ───────────────
NEXTCLOUD_APP_PASSWORD=

# ── Optional: OIDC IdP client secret ─────────────────────────
OIDC_CLIENT_SECRET=
